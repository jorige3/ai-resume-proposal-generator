# Ollama Service Configuration
# Default base URL for local Ollama API (reachable from WSL via Windows host URL)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# The local model to use for generations (e.g. qwen3:1.7b, llama3)
OLLAMA_MODEL=qwen3:1.7b

# API Request Timeout in seconds
OLLAMA_TIMEOUT=120
